# ── Public (exposed to browser) ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Use /api/backend to proxy to the Go API (avoids cross-site cookie issues on Vercel subdomains)
NEXT_PUBLIC_API_URL=/api/backend
NEXT_PUBLIC_CDN_HOST=cdn.yourdomain.com

# Go API base URL (server-side only; used by the proxy route handler)
QWIKKLE_API_URL=http://localhost:8080

# ── Server-only ───────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
REVALIDATION_SECRET=change_me_in_production
